DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/rolematch
PORT=5000

# Optional job-source integrations. RoleMatch still runs without these.
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=us
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_USER_AGENT=your_email_or_app_name

# Optional ATS board lists.
# Lever uses company slugs, e.g. "netflix,ramp".
LEVER_COMPANIES=

# Greenhouse uses board tokens, e.g. "airbnb,stripe".
GREENHOUSE_BOARDS=

# Workday uses label|host|tenant|site entries.
# The default code includes Workday's own public board as a demo source.
WORKDAY_SITES=Workday|workday.wd5.myworkdayjobs.com|workday|Workday

# Indeed and LinkedIn are visible source states, but direct scraping is not implemented.
# Those sources need approved partner/API access or explicit permission.
