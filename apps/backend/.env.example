DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/rolematch
PORT=5000

# Optional job-source integrations. RoleMatch still runs without these.
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=us
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_USER_AGENT=your_email_or_app_name
